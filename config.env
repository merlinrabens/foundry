#!/bin/bash
# Foundry Configuration — Multi-Agent Code Factory
# Three-backend system inspired by Elvis's agent factory architecture

# ─── Paths ────────────────────────────────────────────────────────────
FOUNDRY_DIR="${FOUNDRY_DIR:-$HOME/.foundry}"
SWARM_DIR="${FOUNDRY_DIR}"  # backward compat alias
CLAUDE_BIN="${CLAUDE_BIN:-$(which claude 2>/dev/null || echo "claude")}"
CODEX_BIN="${CODEX_BIN:-$(which codex 2>/dev/null || echo "codex")}"
GEMINI_BIN="${GEMINI_BIN:-$(which gemini 2>/dev/null || echo "gemini")}"
REGISTRY="${FOUNDRY_DIR}/active-tasks.json"

# ─── Foundry v4: SQLite Registry ─────────────────────────────────────────
# Set to "true" to use SQLite instead of active-tasks.json
USE_SQLITE_REGISTRY="${USE_SQLITE_REGISTRY:-true}"
REGISTRY_DB="${REGISTRY_DB:-${FOUNDRY_DIR}/foundry.db}"

# ─── OpenClaw (Reserved) ──────────────────────────────────────────────
# OpenClaw gateway vars — reserved for future direct gateway integration.
# Jerry now acts as orchestrator (picks codex/claude/gemini), not as a worker.
# OPENCLAW_BIN="${OPENCLAW_BIN:-$(which openclaw 2>/dev/null || echo "openclaw")}"
# OPENCLAW_GATEWAY_URL="${OPENCLAW_GATEWAY_URL:-}"
# OPENCLAW_TOKEN_FILE="${OPENCLAW_TOKEN_FILE:-$HOME/.openclaw/gateway.token}"

# ─── Default Models ───────────────────────────────────────────────────
# Claude models
CLAUDE_DEFAULT="${CLAUDE_DEFAULT:-claude-sonnet-4-6}"
CLAUDE_COMPLEX="${CLAUDE_COMPLEX:-claude-opus-4-6}"

# Codex models (requires: npm install -g @openai/codex)
CODEX_MODEL="${CODEX_MODEL:-gpt-5.3-codex}"
CODEX_REASONING="${CODEX_REASONING:-high}"

# Gemini models (free tier: 60 req/min)
GEMINI_MODEL="${GEMINI_MODEL:-gemini-3.5-pro}"

# ─── Elvis's Model Routing ───────────────────────────────────────────
# Codex:  Backend logic, complex bugs, multi-file refactors (workhorse)
# Claude: Frontend, git ops, fast tasks, smaller changes
# Gemini: Design sensibility, UI specs, beautiful UIs
#         (generates HTML/CSS spec → hand to Claude to implement)
DEFAULT_MODEL="${DEFAULT_MODEL:-codex}"

# ─── Limits ───────────────────────────────────────────────────────────
MAX_RETRIES=5
MAX_REVIEW_FIXES="${MAX_REVIEW_FIXES:-20}"  # Review-fix cycle budget (separate from crash retries)
AGENT_TIMEOUT="${AGENT_TIMEOUT:-1800}"   # 30 min per agent
MAX_CONCURRENT=4     # Max parallel agents

# ─── Phase 1.5: Pre-flight Validation ────────────────────────────────
# Run lint/test checks AFTER agent finishes but BEFORE marking as done.
# Catches 80% of CI failures locally, saving a full CI roundtrip.
PREFLIGHT_ENABLED="${PREFLIGHT_ENABLED:-true}"
PREFLIGHT_TIMEOUT=120   # Max seconds for preflight checks

# ─── Phase 1.5: Auto-Merge for LOW Risk PRs ─────────────────────────
# When enabled and all 3 reviews pass + CI green, auto-merge LOW risk PRs.
# LOW risk = docs, tests, UI components, CSS, README only.
# SAFETY: Disabled by default. Set to "true" to enable.
AUTO_MERGE_LOW_RISK="${AUTO_MERGE_LOW_RISK:-false}"

# ─── Phase 1.5: Stale Detection ─────────────────────────────────────
# Flag agents running > STALE_THRESHOLD_SECS without creating a PR.
# Flag agents idle > IDLE_THRESHOLD_SECS with no code changes.
STALE_THRESHOLD_SECS="${STALE_THRESHOLD_SECS:-7200}"   # 2 hours
IDLE_THRESHOLD_SECS="${IDLE_THRESHOLD_SECS:-1800}"      # 30 min

# Known projects (add yours here)
KNOWN_PROJECTS=(
  # "$HOME/projects/my-org/my-repo"
)

# ─── GitHub Issues as Spec Source (per-repo opt-in) ─────────────────────────
# Add the following line to a repo's AGENTS.md to enable GitHub Issues scanning:
#
#   foundry.issues: true
#
# When enabled, `foundry scan` and `foundry orchestrate` will also discover
# open GitHub Issues labelled "foundry" as buildable specs:
#
#   gh issue list -R <owner/repo> --state open --label foundry
#
# Task ID format: <repo-name>-issue-<number>  (e.g., lead-gen-issue-6)
# Agents automatically include "fixes #<number>" in their PR description,
# which auto-closes the issue when the PR is merged.
#
# To spawn from a specific issue:
#   foundry orchestrate ~/projects/lead-gen issue-6
#   foundry spawn       ~/projects/lead-gen issue-6 --issue-number 6
#
# File specs in specs/backlog/ always take priority over GitHub Issues.
# Repos without foundry.issues in AGENTS.md are completely unaffected.

